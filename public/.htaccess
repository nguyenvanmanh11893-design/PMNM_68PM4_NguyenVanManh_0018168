RewriteEngine On
#Không cho xem cấu trúc thư mục
Options -Indexes

#Đảm bảo rằng yêu cầu không phải là một file hoặc thư mục tồn tại
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

#Điều hướng tất cả các yêu cầu tới index.php và truyền tham số url
RewriteRule ^(.*)$ index.php?url=$1  [QSA,L]